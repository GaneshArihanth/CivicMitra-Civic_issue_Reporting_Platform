rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is the owner of a document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check if a user is an official
    // (Requires a document in the users collection with type: "official")
    function isOfficial() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.type == 'official';
    }
    
    // Helper function to check if a post has too many reports
    function isReportedPost(post) {
      return (post.reportCount || 0) >= 30;
    }

    // Complaints collection
    match /complaints/{complaintId} {
      // Allow read if:
      // 1. The post has less than 30 reports, OR
      // 2. The user is the author of the post, OR
      // 3. The user is an official
      allow read: if isAuthenticated();
      
      // Allow create if authenticated
      allow create: if isAuthenticated();
      
      // Allow update if:
      // 1. User is the author (e.g., editing complaint), OR
      // 2. User is an official (e.g., updating status / resolving), OR
      // 3. Any authenticated user is just updating the likes (increment/decrement)
      allow update: if isAuthenticated() && (
        isOwner(resource.data.reportedBy) ||
        isOfficial() ||
        // Only allow changes to the likesCount or updatedAt and nothing else for a non-owner/non-official
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'updatedAt']))
      );
      
      // Allow delete if user is the author or an official
      allow delete: if isOwner(resource.data.reportedBy) || isOfficial();
      
      // Subcollections
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.author == request.auth.uid;
        allow update, delete: if isOwner(resource.data.author) || isOfficial();
      }
      
      match /likes/{likeId} {
        allow read: if isAuthenticated();
        allow create, delete: if isAuthenticated() && request.auth.uid == likeId;
      }
    }
    
    // Reports collection
    match /reports/{reportId} {
      // Only allow users to create reports and view their own reports. Officials can read all.
      allow read: if isOwner(resource.data.userId) || isOfficial();
      allow create: if isAuthenticated();
    }
    
    // Users collection
    match /users/{userId} {
      // Anyone authenticated can read user profiles
      allow read: if isAuthenticated();
      
      // Allow write if:
      // 1. User is the owner of the profile being edited, OR
      // 2. Authenticated user is adding/removing themselves from the 'followers'/'following' arrays
      allow write: if isOwner(userId) || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers', 'following'])
      );
    }
  }
}